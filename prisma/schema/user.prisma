model User {
    id           String     @id @default(uuid())
    name         String
    email        String     @unique
    password     String
    phone        String?
    address      String?
    profileImage String?
    role         Role       @default(CUSTOMER)
    status       UserStatus @default(ACTIVE)

    gearItems      GearItem[]
    rentalOrders   RentalOrder[] @relation("CustomerOrders")
    providerOrders RentalOrder[] @relation("ProviderOrders")
    reviews        Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}
